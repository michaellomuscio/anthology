{
  "name": "anthology",
  "version": "0.8.1",
  "description": "A Mac app for managing multiple Claude Code sessions",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --config electron-builder.config.js",
    "build:signed": "set -a && . ./.env && set +a && npm run build",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-cron": "^4.2.1",
    "node-pty": "^1.0.0",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
