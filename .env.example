# Anthology code-signing + notarization secrets.
# Copy to `.env` and fill in real values, then `source .env && npm run build`.
# .env is gitignored — never commit real secrets.

# Path to your Developer ID Application .p12 (exported from Keychain Access).
# This file holds your code-signing private key.
CSC_LINK="$HOME/.apple-codesign/developer-id.p12"

# Password you set when exporting the .p12.
CSC_KEY_PASSWORD=""

# Apple ID tied to your Developer Program membership.
APPLE_ID=""

# App-specific password from appleid.apple.com (NOT your real Apple ID password).
# Format: xxxx-xxxx-xxxx-xxxx
APPLE_APP_SPECIFIC_PASSWORD=""

# 10-character Team ID from your Apple Developer Membership page.
APPLE_TEAM_ID=""

# Flips on hardenedRuntime + notarization in electron-builder.config.js.
# Without this, builds skip signing and produce a Gatekeeper-warning .dmg.
ANTHOLOGY_SIGN=1
